func ExampleGame() {
	// Initialize game state
	g := &GameState{
		Player: struct {
			Position: nil
			Inventory: make(map[string]int)
		}{
			Position: findRoom("Town Square", g.Rooms),
		},
		Rooms: map[string]*Room{
			"Town Square": {Name: "Town Square", Items: map[string]int{"apple": 3, "sword": 1}},
		},
	}

	// Input handling goroutine
	inputChan := make(chan string)
	var mu sync.Mutex

	go func() {
		scanner := bufio.NewScanner(os.Stdin)
		for scanner.Scan() {
			cmd := strings.TrimSpace(scanner.Text())
			mu.Lock()
			inputChan <- cmd
			mu.Unlock()
		}
	}()

	// Main game loop
	for {
		select {
		case cmd := <-inputChan:
			processCommand(cmd, g)
		}
	}
}
```

