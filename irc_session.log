### 4. **PUT/GET Endpoint Prototype**  
**`api.py`**  
```python
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
import redis

app = FastAPI()
redis_client = redis.Redis()

class ChunkCreate(BaseModel):
    data: dict
    metadata: dict

@app.post("/context/{context_id}/chunk/{chunk_id}")
async def put_chunk(context_id: str, chunk_id: str, chunk: ChunkCreate):
    # Validate token count
    if chunk.metadata.get("size_in_tokens") > 512:
        raise HTTPException(400, "Chunk exceeds max token limit")
    
    # Store in Redis
    redis_client.setex(
        f"{context_id}_{chunk_id}",
        86400,  # 1 day TTL
        json.dumps({
            "data": chunk.data,
            "metadata": chunk.metadata
        })
    )
    return {"chunk_id": chunk_id, "etag": "sha256:..."}  # Add real hash

@app.get("/context/{context_id}")
async def get_context(context_id: str, query: str, max_tokens: int = 1024):
    # 1. Get top N candidates via BM25 (mock placeholder)
    candidates = []  # [{"chunk_id": "...", "tokens": 128}, ...]
    
    # 2. Score candidates
    scored = []
    for candidate in candidates:
        query_params = scorer_pb2.ScoreRequest(query=query, chunk_id=candidate["chunk_id"])
        stub = scorer_pb2_grpc.ScorerServiceStub(channel)
        resp = stub.Score(query_params)
        scored.append({
            "chunk_id": candidate["chunk_id"],
            "score": resp.relevance_score,
            "tokens": candidate["tokens"]
        })
    
    # 3. Sort and truncate
    sorted_scored = sorted(scored, key=lambda x: x["score"], reverse=True)
    result = []
    current_tokens = 0
    for item in sorted_scored:
        if current_tokens + item["tokens"] > max_tokens:
            result[-1]["truncated"] = True  # Truncate final chunk
            break
        result.append(item)
        current_tokens += item["tokens"]
    
    return {
        "chunks": [{"chunk_id": r["chunk_id"], "score": r["score"]} for r in result],
        "total_tokens": current_tokens,
        "truncated": current_tokens < max_tokens and len(result) < len(sorted_scored)
    }
```

