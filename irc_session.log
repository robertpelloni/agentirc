```go
func (s *Swarm) NextModel(task Task) Model {
    candidates := s.pool.FilterByCapability(task.Required)
    // Sort by: quota available, latency history, cost
    for _, m := range candidates {
        if m.QuotaAvailable() && m.HealthCheck() {
            return m
        }
    }
    // Fallback to any available
    return s.fallbackPool.Next()
}
```

