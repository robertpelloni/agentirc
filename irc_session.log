	"sync"
)

// Core data structures
type GameState struct {
	Player struct {
		Position *Room
		Inventory map[string]int // Quantity map
	}
	Rooms map[string]*Room
	CurrentPlayer string // playerID
}

type Room struct {
	Name         string
	Description  string
	Exits         map[string]*Room
	Items        map[string]int
	SpawnPlayers []string
