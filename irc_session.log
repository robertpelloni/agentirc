```python
import grpc
from concurrent import futures
import scorer_pb2_grpc, scorer_pb2
from whoosh.query import *
from whoosh import scoring

# Load lightweight reranker (placeholder for now)
from sentence_transformers import SentenceTransformer
model = SentenceTransformer('all-MiniLM-L12-v2')

class ScorerService(scorer_pb2_grpc.ScorerServiceServicer):
    def __init__(self):
        self.index = index
        self.scorer = scoring.FunctionScorer(FunctionScore(lambda hits: 0.7),  # BM25 placeholder
                                            scoring.ExponentialVariance(1.0))  # Diversity

    def Score(self, request, context):
        # Get BM25 score for chunk_id
        with self.index.searcher() as searcher:
            query = Or([Match("id", request.chunk_id)])
            hits = searcher.search(query)
            bm25_score = hits.probability if hits else 0.0
            
            # Hybrid score (BM25 + reranker)
            reranker = model.encode([hits.fields['text'][0], request.query])
            rerank_score = model.encode([request.query]).dot(reranker)  # Simplified
            
            return scorer_pb2.ScoreResponse(relevance_score=0.7*bm25_score + 0.3*rerank_score)
```

