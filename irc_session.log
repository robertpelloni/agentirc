```go
package main

import (
	"bufio"
	"encoding/json"
	"fmt"
	"os"
	"strings"
)

// ---------- Data structures ----------
type Game struct {
	Player   *Player          // only one player for now
	Rooms    map[string]*Room // name → room
	cmdChan  chan string
	quitChan chan struct{}
}

type Player struct {
	Current *Room
	Inv     map[string]int // item → count
}

type Room struct {
	Name        string
	Description string
	Exits       map[string]*Room // direction → room
	Items       map[string]int   // item → count
}

// ---------- Game methods ----------
func NewGame() *Game {
	g := &Game{
		Rooms:    make(map[string]*Room),
		cmdChan:  make(chan string),
		quitChan: make(chan struct{}),
	}
	g.buildWorld()
	g.Player = &Player{
		Inv: make(map[string]int),
	}
	// start player in the "Town Square"
	g.Player.Current = g.Rooms["Town Square"]
	return g
}

// tiny world builder – you can expand it later
func (g *Game) buildWorld() {
	ts := &Room{
		Name:        "Town Square",
		Description: "You stand in a bustling town square. Paths lead north and east.",
		Exits:       make(map[string]*Room),
		Items:       map[string]int{"coin": 5, "apple": 2},
	}
	forest := &Room{
		Name:        "Enchanted Forest",
		Description: "Tall trees loom overhead. A faint path goes south.",
		Exits:       make(map[string]*Room),
		Items:       map[string]int{"mushroom": 1},
	}
	market := &Room{
		Name:        "Market",
		Description: "Stalls line the street. You can hear merchants shouting.",
		Exits:       make(map[string]*Room),
		Items:       map[string]int{"sword": 1},
	}

	// wire exits
	ts.Exits["north"] = forest
	ts.Exits["east"] = market
	forest.Exits["south"] = ts
	market.Exits["west"] = ts

	// register rooms
	g.Rooms[ts.Name] = ts
	g.Rooms[forest.Name] = forest
	g.Rooms[market.Name] = market
}

// ----------------------------------------------------------------
// Input handling – runs in its own goroutine
func (g *Game) startInputReader() {
	go func() {
		scanner := bufio.NewScanner(os.Stdin)
		fmt.Print("> ")
		for scanner.Scan() {
			line := strings.TrimSpace(scanner.Text())
			// allow graceful quit
			if line == "quit" || line == "exit" {
				close(g.quitChan)
				return
			}
			g.cmdChan <- line
			fmt.Print("> ")
		}
		// EOF (Ctrl‑D) also quits
		close(g.quitChan)
	}()
}

// ----------------------------------------------------------------
// Core command processor – runs in the main goroutine
func (g *Game) run() {
	for {
		select {
		case <-g.quitChan:
			fmt.Println("\nGood‑bye!")
			return
		case cmd := <-g.cmdChan:
			g.handleCommand(strings.ToLower(cmd))
		}
	}
}

func (g *Game) handleCommand(cmd string) {
	parts := strings.Fields(cmd)
	if len(parts) == 0 {
		return
	}
	switch parts[0] {
	case "look":
		g.describeCurrentRoom()
	case "go":
		if len(parts) < 2 {
			fmt.Println("Go where?")
			return
		}
		g.movePlayer(parts[1])
	case "inv", "inventory":
		g.showInventory()
	case "pick", "take":
		if len(parts) < 2 {
			fmt.Println("Pick what?")
			return
		}
		g.takeItem(parts[1])
	case "drop":
		if len(parts) < 2 {
			fmt.Println("Drop what?")
			return
		}
		g.dropItem(parts[1])
	case "save":
		if len(parts) < 2 {
			fmt.Println("save <filename>")
			return
		}
		g.saveGame(parts[1])
	case "load":
		if len(parts) < 2 {
			fmt.Println("load <filename>")
			return
		}
		g.loadGame(parts[1])
	default:
		fmt.Println("I don't understand that command.")
	}
}

// ----------------------------------------------------------------
// Helper methods
func (g *Game) describeCurrentRoom() {
	r := g.Player.Current
	fmt.Printf("\n=== %s ===\n%s\n", r.Name, r.Description)
	if len(r.Items) > 0 {
		fmt.Print("You see: ")
		for it, cnt := range r.Items {
			fmt.Printf("%s(%d) ", it, cnt)
		}
		fmt.Println()
	}
	if len(r.Exits) > 0 {
		fmt.Print("Exits: ")
		for dir := range r.Exits {
			fmt.Printf("%s ", dir)
		}
		fmt.Println()
	}
	fmt.Println()
}

func (g *Game) movePlayer(dir string) {
	cur := g.Player.Current
	if nxt, ok := cur.Exits[dir]; ok {
		g.Player.Current = nxt
		g.describeCurrentRoom()
	} else {
		fmt.Println("You can't go that way.")
	}
}

func (g *Game) showInventory() {
	if len(g.Player.Inv) == 0 {
		fmt.Println("Your inventory is empty.")
		return
	}
	fmt.Println("You carry:")
	for it, cnt := range g.Player.Inv {
		fmt.Printf("- %s (%d)\n", it, cnt)
	}
}

func (g *Game) takeItem(item string) {
	r := g.Player.Current
	if cnt, ok := r.Items[item]; ok && cnt > 0 {
		r.Items[item]--
		if r.Items[item] == 0 {
			delete(r.Items, item)
		}
		g.Player.Inv[item]++
		fmt.Printf("You pick up the %s.\n", item)
	} else {
		fmt.Printf("There is no %s here.\n", item)
	}
}

func (g *Game) dropItem(item string) {
	if cnt, ok := g.Player.Inv[item]; ok && cnt > 0 {
		g.Player.Inv[item]--
		if g.Player.Inv[item] == 0 {
			delete(g.Player.Inv, item)
		}
		r := g.Player.Current
		r.Items[item]++
		fmt.Printf("You drop the %s.\n", item)
	} else {
		fmt.Printf("You don't have a %s.\n", item)
	}
}

// Simple JSON persistence – suitable for a prototype
func (g *Game) saveGame(fname string) {
	f, err := os.Create(fname)
	if err != nil {
		fmt.Println("Cannot create file:", err)
		return
	}
	defer f.Close()
	enc := json.NewEncoder(f)
	// we only need to serialise the player and rooms (rooms are static, but ok)
	if err := enc.Encode(g); err != nil {
		fmt.Println("Save failed:", err)
	} else {
		fmt.Println("Game saved to", fname)
	}
}

func (g *Game) loadGame(fname string) {
	f, err := os.Open(fname)
	if err != nil {
		fmt.Println("Cannot open file:", err)
		return
	}
	defer f.Close()
	dec := json.NewDecoder(f)
	// create a new empty game to unmarshal into
	newG := NewGame()
	if err := dec.Decode(newG); err != nil {
		fmt.Println("Load failed:", err)
		return
	}
	// replace current state (rooms are the same references already)
	*g = *newG
	fmt.Println("Game loaded from", fname)
	g.describeCurrentRoom()
}

// ----------------------------------------------------------------
func main() {
	game := NewGame()
	game.describeCurrentRoom()
	game.startInputReader()
	game.run()
}
```

### How it fits the goals you mentioned  

| Goal | Where it appears in the code |
|------|------------------------------|
| **Room navigation** | `Room.Exits`, `movePlayer`, `Enter/Exit` logic is inside `movePlayer` (you can split it into explicit `EnterRoom`/`ExitRoom` later). |
| **Inventory management** | `Player.Inv`, `takeItem`, `dropItem`. |
| **Persistence** | `saveGame` / `loadGame` using `encoding/json`. |
| **Concurrency pattern** | One **input goroutine** writes to `cmdChan`; the main goroutine selects on `cmdChan` and `quitChan`. No mutexes needed because all game state lives in the main loop. |
| **Scalable foundation** | All structs are pointer‑based, making it easy to add more fields (e.g., NPCs, quests) without changing signatures. |

---

## Next “manual” steps you can take

1. **Refactor into packages** – move `game`, `player`, `room` into separate files or a `game` package. This mirrors how larger Go projects are organised.  
2. **Replace the linear command parser with a table‑driven one** – a map from command string to handler function makes adding new verbs trivial.  
3. **Add a simple tick system** – spawn a goroutine that sends a “tick” message on another channel every N milliseconds; the main loop can react (e.g., spawn monsters, decay items).  
4. **Performance tweaks** – if you ever hit GC pressure, consider:
   * Using `[]byte` pools (`sync.Pool`) for large text buffers.  
   * Keeping item counts in slices rather than maps when the item set is static.  
5. **Testing** – write a few `*_test.go` files that drive `handleCommand` programmatically. Go’s testing harness will catch regressions early.

---

### Want deeper on any of those points?

* **Channels & select patterns** – why the single‑producer / single‑consumer model avoids locks.  
* **sync.Map vs plain map + mutex** – when each makes sense for a game.  
* **JSON vs Gob vs binary** – trade‑offs for persistence.  
* **Extending to multiple players** – shared world + per‑player goroutine model.

